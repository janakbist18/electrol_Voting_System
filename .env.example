# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-min-50-chars-random
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_SETTINGS_MODULE=nepal_voting.settings

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=nepal_voting_db
DB_USER=nepal_voting_user
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration (SendGrid)
EMAIL_BACKEND=sendgrid_backend.SendgridBackend
SENDGRID_API_KEY=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
ADMINS_EMAIL=admin@yourdomain.com

# Email Configuration (SMTP - Alternative)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# OTP Configuration
OTP_TIMEOUT=600
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# reCAPTCHA
RECAPTCHA_PUBLIC_KEY=your-recaptcha-public-key
RECAPTCHA_PRIVATE_KEY=your-recaptcha-private-key

# JWT/Token Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Celery/Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Firebase (Optional - for push notifications)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id

# AWS S3 (Optional - for media storage)
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=ap-south-1

# Security Settings
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=your-sentry-dsn

# Voting Settings
VOTING_ENABLED=True
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=1800
MINIMUM_VOTER_AGE=18

# Admin Settings
ADMIN_URL=admin/
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com

# Application Settings
SITE_NAME=Nepal Election Voting System
SITE_URL=https://yourdomain.com
SITE_LOGO_URL=https://yourdomain.com/static/logo.png

# Notification Settings
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_SMS_NOTIFICATIONS=True
ENABLE_PUSH_NOTIFICATIONS=False

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_LOGIN_PER_HOUR=5

# Audit Logging
AUDIT_LOG_ENABLED=True
AUDIT_LOG_RETENTION_DAYS=365

# Feature Flags
FEATURE_2FA=True
FEATURE_GOOGLE_OAUTH=True
FEATURE_USER_DASHBOARDS=True
FEATURE_ADMIN_DASHBOARDS=True
FEATURE_RESULTS_ANALYTICS=True

